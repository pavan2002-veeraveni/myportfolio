{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "resume.pdf",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/upload", "dest": "server.js" },
    { "src": "/assets/(.*)", "dest": "assets/$1" },
    { "src": "/styles.css", "dest": "styles.css" },
    { "src": "/script.js(.*)", "dest": "script.js" },
    { "src": "/resume.pdf", "dest": "resume.pdf" },
    { "src": "/(.*\\.html)?$", "dest": "index.html" }
  ]
}
